local RemoteHandler = ReplicatedStorage:WaitForChild("RemoteHandler", 10)
local FishingEvent = RemoteHandler and RemoteHandler:FindFirstChild("Fishing")
local UpgradeEvent = RemoteHandler and RemoteHandler:FindFirstChild("Upgrade")
local PlotEvent = RemoteHandler and RemoteHandler:FindFirstChild("Plot")
local SellEvent = RemoteHandler and RemoteHandler:FindFirstChild("SellMultiple")

local function CreateLoop(toggleKey, delayTime, action)
    task.spawn(function()
        while true do
            if Toggles[toggleKey] then
                pcall(action)
                task.wait(delayTime)
            else
                task.wait(0.5)
            end
        end
    end)
end

if FishingEvent then
    CreateLoop("AutoFish", 1, function()
